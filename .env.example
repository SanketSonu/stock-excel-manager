# Copy to .env and fill in real values. The .env file itself is gitignored.

# Kite Connect (https://developers.kite.trade/apps)
KITE_API_KEY=
KITE_API_SECRET=

# Optional: pre-seeded access token (the Streamlit app will overwrite per session)
KITE_ACCESS_TOKEN=

# Path to the local Excel workbook (used by app_local.py only)
STOCK_EXCEL_PATH=/path/to/Stocks_2026_Latest.xlsx

# Sheet name inside the workbook
STOCK_SHEET_NAME=Stock Report 2026

# Optional: kite request throttle (seconds between calls)
KITE_REQUEST_DELAY_SECONDS=0.35

# Used by app_deploy.py only — Drive file ID of the Excel
GDRIVE_FILE_ID=
